    {
      "parameters": {
        "jsCode": "const responseText = $input.item.json.choices[0].message.content;\nconst hubspotMsg = $('Obtener Mensaje de HubSpot').item.json;\nconst userMessage = hubspotMsg.text || '';\n\nlet nombreCliente = '';\nlet reply = responseText;\n\n// Detectar nombre del mensaje del usuario con patrones naturales\nconst patronesPregunta = [\n  /(?:soy|me llamo|mi nombre es|soy la|soy el)\\s+([A-Za-záéíóúÁÉÍÓÚñÑ]+)/i,\n];\n\nfor (const patron of patronesPregunta) {\n  const match = userMessage.match(patron);\n  if (match) {\n    nombreCliente = match[1].trim();\n    break;\n  }\n}\n\nreturn [{\n  json: {\n    reply: reply,\n    nombreCliente: nombreCliente,\n    hubspotBody: JSON.stringify({\n      text: reply,\n      type: 'MESSAGE',\n      channelId: hubspotMsg.channelId,\n      channelAccountId: hubspotMsg.channelAccountId,\n      senderActorId: 'YOUR_HUBSPOT_BOT_ACTOR_ID'\n    })\n  }\n}];"
      },
