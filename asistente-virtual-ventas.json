    {
      "parameters": {
        "jsCode": "const reply = $('Airtable - Guardar Respuesta del Asistente').item.json.Contenido || \n              $('Airtable - Guardar Respuesta del Asistente').item.json.fields?.Contenido || \n              $('Código - Extraer Respuesta').item.json.reply;\n\nconst threadId = $('Airtable - Buscar Hilo').item.json.id || $('Airtable - Crear Hilo').item.json.id;\n\nconst productos = [\n  'Vestido Floral', 'Vestido Satinado Negro', 'Vestido Casual Rayas', 'Vestido Lencero Beige',\n  'Jean Mom Fit', 'Jean Skinny Negro', 'Jean Wide Leg',\n  'Blusa Satinada Pastel', 'Blusa Campesina Blanca', 'Blusa Crop Flores', 'Blusón Oversize Beige', 'Blusón Estampado',\n  'Tacón Stiletto Negro', 'Tacón Destalonado Nude', 'Sandalia Tacón Dorada',\n  'Sombrero Playero', 'Sombrero Trenzado Rosa', 'Boina Francesa Negra',\n  'Correa Cuero Café', 'Correa Dorada Metálica'\n];\n\nconst replyNorm = reply.toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n\nconst productosEncontrados = productos.filter(p => {\n  const pNorm = p.toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n  const palabras = pNorm.split(' ');\n  return palabras.every(palabra => replyNorm.includes(palabra));\n});\n\nif (productosEncontrados.length === 0) {\n  return [{ json: { skip: true, threadId, fecha: new Date().toISOString() } }];\n}\n\nconst productosUnicos = [...new Set(productosEncontrados)];\n\nreturn productosUnicos.map(producto => ({\n  json: { skip: false, producto, threadId, fecha: new Date().toISOString() }\n}));"
      },
